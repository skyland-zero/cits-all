{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Jwt": {
    "SecretKey": "b3128845-a945-4504-a79f-498bc05ffbed",
    "Issuer": "https://yourdomain.com",
    "Audience": "https://yourdomain.com",
    "ExpiryHours": 60,
    "RefreshExpireHours": 144
  },
  "DbConfig": {
    "UseLocal": true
  },
  "ConnectionStrings": {
    "Local": "Data Source=cits.db",
    "Remote": "Host=192.168.10.227;Port=25432;Username=admin;Password=1234qwer.; Database=cits;ArrayNullabilityMode=Always;Pooling=true;Minimum Pool Size=1",
    "LocalRedis": "localhost:6379,password=",
    "RemoteRedis": "192.168.10.227:16378,password=1234qwer."
  },
  "Permission": {
    "Enabled": true
  },
  "AllowedHosts": "*",
  "StorageConfig": {
    "Type": "Local", // 可选: Local 或 Minio
    "TempSubFolder": "temp",
    "BusinessSubFolder": "business",
    "Local": {
      "Paths": [
        "./data/storage1",
        "./data/storage2"
      ],
      "MinFreeGB": 1.0
    },
    "Minio": {
      "Endpoint": "localhost:9000",
      "AccessKey": "minioadmin",
      "SecretKey": "minioadmin",
      "BucketName": "uploads",
      "UseSSL": false
    }
  },
  "FileValidation": {
    "MaxFileSizeMB": 500,
    "AllowedExtensions": [
      ".jpg",
      ".png",
      ".pdf",
      ".zip",
      ".docx",
      ".xlsx"
    ]
  },
  "UploadOptions": {
    "Client": {
      "MaxConcurrentUploads": 3
    },
    "SignedUrl": {
      "SecretKey": "CHANGE_ME_TO_A_STRONG_UPLOAD_SIGNING_SECRET_KEY",
      "PreviewTtlMinutes": 10,
      "DownloadTtlMinutes": 10
    },
    "SignalR": {
      "Enabled": true
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore.Mvc": "Warning",
        "Microsoft.AspNetCore.Routing": "Warning",
        "Microsoft.AspNetCore.Hosting": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "File",
        "Args": {
          "path": "./logs/log-.txt",
          "rollingInterval": "Day"
        }
      },
      {
        "Name": "Console"
      }
    ]
  }
}
